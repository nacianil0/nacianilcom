# HMAC secret for /api/revalidate (Studio → Web cache invalidation, §29)
# Generate: openssl rand -hex 32
# NEVER use NEXT_PUBLIC_ prefix — must stay server-only
REVALIDATE_SECRET=replace-with-a-strong-random-secret

# Vercel cron authentication for /api/cron — Vercel sets this automatically.
# Copy to .env.local for local testing; leave unset to skip auth in local dev.
CRON_SECRET=replace-with-a-strong-random-secret

# Fallback origin for the printable CV's live link + QR code (src/lib/origin.ts).
# Priority: runtime/export request origin → NEXT_PUBLIC_SITE_URL → SITE_URL constant.
# Set this when exporting the PDF from localhost so the QR points to the public
# site instead of the SITE_URL fallback. Public by contract — never a secret.
# (Canonical URLs / sitemap / OG use the SITE_URL constant in src/lib/site.ts.)
NEXT_PUBLIC_SITE_URL=https://nacianil.com

# Password-only private gate for apps/web. Leave unset to disable the gate.
# Generate hash:
#   node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('your-password')).then(b=>console.log([...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,'0')).join('')))"
SITE_PASSWORD_SHA256=replace-with-sha256-password-hash

# HMAC secret for the 1-hour httpOnly auth cookie.
# Generate: openssl rand -hex 32
AUTH_COOKIE_SECRET=replace-with-a-strong-random-secret

# ── Security notes (§29) ──────────────────────────────────────────────────────
# • Only NEXT_PUBLIC_SITE_URL is public (a base URL, no secret); all else server-only.
# • Build logs must never contain these values — verify before CI promotion.
# • Studio-only vars live in apps/studio/.env.example (never overlap).

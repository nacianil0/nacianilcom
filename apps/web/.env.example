# Secret for HMAC-signed revalidate requests from Studio Publisher.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=replace-with-a-strong-random-secret

# Secret Vercel passes automatically when invoking cron routes.
# On Vercel, set this in project settings; locally leave unset to skip cron auth.
CRON_SECRET=replace-with-a-strong-random-secret

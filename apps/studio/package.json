{
  "name": "@nacianilcom/studio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently --names server,client \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src server",
    "start": "node dist/server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@nacianilcom/content-core": "workspace:*",
    "@nacianilcom/ui": "workspace:*",
    "@mdx-js/mdx": "^3.1.0",
    "fastify": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@eslint/js": "^9.18.0",
    "globals": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "eslint": "^9.18.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.1.1"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# nacianilcom — Environment Variables
# Copy relevant sections to apps/web/.env or apps/studio/.env
# Never commit .env files. Vercel secrets → project settings (server-only).
# ─────────────────────────────────────────────────────────────────────────────

# ── apps/web ─────────────────────────────────────────────────────────────────

# HMAC-SHA256 secret for /api/revalidate. Min 32 chars.
# Vercel: Environment Variables → Server-only
REVALIDATE_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Vercel cron auth for /api/cron (Vercel passes as Authorization: Bearer).
# Vercel: Environment Variables → Server-only
CRON_SECRET=replace-with-a-strong-random-secret

# ── apps/studio (local only — never deployed) ─────────────────────────────────

# Same REVALIDATE_SECRET as above — Studio calls /api/revalidate after publish.
# Place in apps/studio/.env (gitignored)
# REVALIDATE_SECRET=same-value-as-web

# Local web server URL (Playwright PDF + post-publish revalidate call).
# Default: http://localhost:3000
# WEB_URL=http://localhost:3000

# ── Optional (LLM — local Studio only, never Vercel) ─────────────────────────

# Anthropic API key — only if LLM Studio features are added. Local only.
# ANTHROPIC_API_KEY=sk-ant-...

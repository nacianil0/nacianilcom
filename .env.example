# nacianil.com — environment variables
# Copy to .env and fill in values. Never commit .env.

# Revalidation (WP-07)
# REVALIDATE_SECRET=your-hmac-secret-here
# REVALIDATE_URL=https://nacianil.com/api/revalidate

# Studio API keys — local only, never public (WP-06/WP-09)
# OPENAI_API_KEY=sk-...

# Next.js public vars (safe to expose)
# NEXT_PUBLIC_SITE_URL=https://nacianil.com
